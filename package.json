{
  "name": "socketio-microservice",
  "version": "1.0.0",
  "description": "A Socket.IO microservice for real-time game handling.",
  "main": "src/server.js",
  "scripts": {
    "start": "node --no-deprecation src/server.js",
    "dev": "nodemon --no-deprecation src/server.js",
    "start:server": "node --no-deprecation src/server.js --no-cron",
    "start:cron": "node --no-deprecation src/cron-worker.js",
    "start:admin": "node --no-deprecation src/admin-worker.js",
    "mock:apis": "node scripts/mock-auth-apis.js",
    "test:socket-connect": "node scripts/test-socket-connect.js",
    "test:ludo-flow": "node scripts/test-ludo-flow.js",
    "test:aurora": "node scripts/test-aurora.js",
    "test:s3": "node scripts/test-s3.js",
    "dev:server": "nodemon --no-deprecation src/server.js --no-cron",
    "dev:cron": "nodemon --no-deprecation src/cron-worker.js",
    "dev:admin": "nodemon --no-deprecation src/admin-worker.js",
    "backup-schema": "node src/database/backupSchema.js"
  },
  "keywords": [
    "fastify",
    "socket.io",
    "microservice",
    "realtime",
    "games"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@fastify/cors": "^8.4.0",
    "@fastify/helmet": "^10.0.0",
    "axios": "^1.13.2",
    "cassandra-driver": "^4.6.4",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.20.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
